{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Demo – S3 River Flood",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run_demo.py",
      "args": ["--scenario", "S3", "--seed", "42"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Run Demo – S2 Flash Flood",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run_demo.py",
      "args": ["--scenario", "S2", "--seed", "42"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Run Demo – S5 Medical Emergency",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run_demo.py",
      "args": ["--scenario", "S5", "--seed", "42"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Run Demo – All Scenarios",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run_demo.py",
      "args": ["--all"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Run Dashboard",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "args": ["run", "dashboard/app.py"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Run Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/", "-v"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Run API Server",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["backend.api.app:app", "--reload", "--port", "8000"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}
